# Supabase PostgreSQL connection string.
# Use the pooled connection string from Supabase for DATABASE_URL.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1"

# Use the direct connection string for Prisma migrations.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# NextAuth
AUTH_SECRET="replace-with-a-random-secret"
AUTH_URL="http://localhost:3000"
# Set this to true for self-hosted or reverse-proxy deployments.
AUTH_TRUST_HOST="true"

# Supabase client values
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
